<Window x:Class="Voxto.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voxto"
        SizeToContent="Width"
        MinWidth="160"
        Height="40"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False"
        ContentRendered="OnContentRendered">

    <Border CornerRadius="8"
            Background="#CC1a1a1a"
            BorderBrush="#FF444444"
            BorderThickness="1"
            Padding="12,6">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Brand state icon — source set from code-behind based on AppState.
                 Pulses opacity so it reads as an active indicator, not a static logo. -->
            <Image x:Name="StateIcon"
                   Width="18" Height="18"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0">
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.35"
                                                 Duration="0:0:0.8"
                                                 AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <!-- Message text — set from code-behind -->
            <TextBlock x:Name="MessageText"
                       Text="Recording…"
                       Foreground="White"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
