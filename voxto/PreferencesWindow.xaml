<Window x:Class="Voxto.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voxto — Preferences"
        Width="860"
        Height="700"
        MinWidth="760"
        MinHeight="620"
        Background="#F3F6FB"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F6FB"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleForegroundBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CardDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource SubtleForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="TabBorder"
                                    Background="#EEF2FF"
                                    CornerRadius="14"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="28,24"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Preferences"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryForegroundBrush}"/>
                        <TextBlock Text="Manage general behavior, output destinations, and update preferences."
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource SubtleForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <TabControl x:Name="PreferencesTabs"
                            Grid.Row="1"
                            Margin="20,18,20,20">
                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8,4,8,8">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Transcription model" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Choose the local Whisper model Voxto uses when transcribing recordings."
                                                   Style="{StaticResource CardDescriptionStyle}"/>
                                        <ComboBox x:Name="ModelCombo" Width="280" HorizontalAlignment="Left">
                                            <ComboBoxItem Tag="Tiny"         Content="Tiny  (~75 MB, fastest)"/>
                                            <ComboBoxItem Tag="Small"        Content="Small  (~244 MB, balanced)"/>
                                            <ComboBoxItem Tag="Medium"       Content="Medium  (~769 MB, accurate)"/>
                                            <ComboBoxItem Tag="LargeV3Turbo" Content="Large V3 Turbo  (~809 MB, best)"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Recording hotkey" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Pick how your global hotkey should behave while recording."
                                                   Style="{StaticResource CardDescriptionStyle}"/>
                                        <RadioButton x:Name="RadioToggle"
                                                     Content="Toggle — press once to start, press again to stop"
                                                     GroupName="HotkeyMode"/>
                                        <RadioButton x:Name="RadioPushToTalk"
                                                     Content="Push-to-talk — hold to record, release to stop"
                                                     GroupName="HotkeyMode"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="System behavior" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Control how Voxto behaves when Windows starts."
                                                   Style="{StaticResource CardDescriptionStyle}"/>
                                        <CheckBox x:Name="StartupCheck"
                                                  Content="Launch Voxto automatically at Windows startup"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Updates" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Check for newer releases automatically or trigger a manual check."
                                                   Style="{StaticResource CardDescriptionStyle}"/>
                                        <CheckBox x:Name="AutoUpdateCheck"
                                                  Content="Check for updates automatically"
                                                  Checked="OnAutoUpdateChanged"
                                                  Unchecked="OnAutoUpdateChanged"/>
                                        <CheckBox x:Name="AutoInstallUpdateCheck"
                                                  Margin="0,8,0,0"
                                                  Content="Automatically download, install, and restart when an update is available"/>

                                        <Grid x:Name="UpdateFrequencyRow" Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Frequency"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                                            <ComboBox x:Name="UpdateIntervalCombo"
                                                      Grid.Column="1"
                                                      Margin="12,0,0,0">
                                                <ComboBoxItem Tag="Daily"  Content="Daily"/>
                                                <ComboBoxItem Tag="Weekly" Content="Weekly"/>
                                            </ComboBox>
                                        </Grid>

                                        <DockPanel Margin="0,18,0,0" LastChildFill="False">
                                            <Button x:Name="CheckNowBtn"
                                                    Content="Check now"
                                                    Width="120"
                                                    Click="OnCheckNow"/>
                                            <TextBlock x:Name="LastCheckedText"
                                                       Margin="14,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="About">
                        <Grid Margin="32">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                                <Border Width="72"
                                        Height="72"
                                        CornerRadius="36"
                                        Background="#DCFCE7"
                                        BorderBrush="#BBF7D0"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="V"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               Foreground="#166534"/>
                                </Border>

                                <TextBlock Text="Voxto"
                                           Margin="0,20,0,0"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource PrimaryForegroundBrush}"/>

                                <TextBlock x:Name="VersionText"
                                           Margin="0,8,0,18"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource SubtleForegroundBrush}"/>

                                <TextBlock Text="A lightweight Windows speech-to-text recorder powered by OpenAI Whisper. Press your hotkey, speak, and your words land wherever you need them."
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource SubtleForegroundBrush}"
                                           LineHeight="22"/>

                                <Border Margin="0,24,0,0"
                                        Padding="18,14"
                                        CornerRadius="16"
                                        Background="#F0FDF4"
                                        BorderBrush="#BBF7D0"
                                        BorderThickness="1">
                                    <TextBlock Text="Runs entirely on your machine using a local Whisper model. Your audio and transcriptions never leave your device."
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="#166534"
                                               LineHeight="22"/>
                                </Border>

                                <TextBlock Margin="0,24,0,0"
                                           HorizontalAlignment="Center">
                                    <Hyperlink x:Name="RepoLink"
                                               NavigateUri="https://github.com/onexey/voxto"
                                               RequestNavigate="OnOpenRepo">
                                        View source on GitHub
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Border Grid.Row="2"
                        Padding="24,18"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Width="110"
                                Margin="0,0,10,0"
                                IsCancel="True"
                                Click="OnCancel"/>
                        <Button Content="Save changes"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                IsDefault="True"
                                Click="OnSave"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
