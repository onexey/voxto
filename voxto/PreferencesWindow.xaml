<Window x:Class="Voxto.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voxto — Preferences"
        Width="460" Height="540"
        MinWidth="400" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>

        <!-- Section header label style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin"     Value="0,14,0,5"/>
        </Style>

        <!-- Subtle horizontal rule below section headers -->
        <Style x:Key="Rule" TargetType="Separator">
            <Setter Property="Margin"     Value="0,-2,0,6"/>
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ── Bottom button bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="80" Height="28"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnCancel"/>
                <Button Content="Save"
                        Width="80" Height="28"
                        IsDefault="True"
                        Click="OnSave"/>
            </StackPanel>
        </Border>

        <!-- ── Tab control ─────────────────────────────────────────────────── -->
        <TabControl Margin="0" Padding="0">

            <!-- ════════════════  GENERAL  ════════════════ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20,8,20,16">

                        <!-- Model ──────────────────────────────────────────── -->
                        <TextBlock Text="WHISPER MODEL" Style="{StaticResource SectionHeader}"/>
                        <Separator Style="{StaticResource Rule}"/>

                        <ComboBox x:Name="ModelCombo" Height="26" Margin="0,0,0,0">
                            <ComboBoxItem Tag="Tiny"         Content="Tiny  (~75 MB, fastest)"/>
                            <ComboBoxItem Tag="Small"        Content="Small  (~244 MB, balanced)"/>
                            <ComboBoxItem Tag="Medium"       Content="Medium  (~769 MB, accurate)"/>
                            <ComboBoxItem Tag="LargeV3Turbo" Content="Large V3 Turbo  (~809 MB, best)"/>
                        </ComboBox>

                        <!-- Hotkey Mode ─────────────────────────────────────── -->
                        <TextBlock Text="HOTKEY MODE" Style="{StaticResource SectionHeader}"/>
                        <Separator Style="{StaticResource Rule}"/>

                        <RadioButton x:Name="RadioToggle"
                                     Content="Toggle — press once to start, press again to stop"
                                     GroupName="HotkeyMode"
                                     Margin="0,2,0,2"/>
                        <RadioButton x:Name="RadioPushToTalk"
                                     Content="Push-to-talk — hold to record, release to stop"
                                     GroupName="HotkeyMode"
                                     Margin="0,2,0,0"/>

                        <!-- Output ──────────────────────────────────────────── -->
                        <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>
                        <Separator Style="{StaticResource Rule}"/>

                        <!-- Output checkboxes populated from code-behind -->
                        <StackPanel x:Name="OutputsPanel" Margin="0,0,0,6"/>

                        <!-- Todo file path row — enabled only when TodoAppend is checked -->
                        <DockPanel x:Name="TodoFileRow" Margin="18,4,0,0">
                            <TextBlock Text="File:" Width="34"
                                       VerticalAlignment="Center"
                                       Foreground="#555"/>
                            <Button x:Name="BrowseTodoBtn"
                                    DockPanel.Dock="Right"
                                    Content="Browse…"
                                    Width="70" Height="24"
                                    Margin="6,0,0,0"
                                    Click="OnBrowseTodoFile"/>
                            <TextBox x:Name="TodoFileBox"
                                     Height="24"
                                     VerticalContentAlignment="Center"
                                     FontSize="11"
                                     ToolTip="Path to the todo Markdown file"/>
                        </DockPanel>

                        <!-- System ──────────────────────────────────────────── -->
                        <TextBlock Text="SYSTEM" Style="{StaticResource SectionHeader}"/>
                        <Separator Style="{StaticResource Rule}"/>

                        <CheckBox x:Name="StartupCheck"
                                  Content="Launch Voxto automatically at Windows startup"
                                  Margin="0,2"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════  ABOUT  ════════════════ -->
            <TabItem Header="About">
                <Grid>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="32">

                        <!-- Logo dot -->
                        <Ellipse Width="52" Height="52"
                                 Fill="#22C55E"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Voxto"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="VersionText"
                                   FontSize="11"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,14"/>

                        <TextBlock TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="340"
                                   Foreground="#555"
                                   LineHeight="20"
                                   Text="A lightweight Windows speech-to-text recorder powered by OpenAI Whisper. Press your hotkey, speak, and your words land wherever you need them."/>

                        <Separator Margin="0,20,0,16" Background="#DDD"/>

                        <TextBlock HorizontalAlignment="Center" FontSize="12">
                            <Hyperlink x:Name="RepoLink"
                                       NavigateUri="https://github.com/"
                                       RequestNavigate="OnOpenRepo">
                                View source on GitHub
                            </Hyperlink>
                        </TextBlock>

                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
